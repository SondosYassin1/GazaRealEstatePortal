<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ViewData["Title"] - بوابة غزة للعقارات</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="~/css/main.css" asp-append-version="true">
</head>
<body class="bg-light">

<div class="dashboard-layout">
  
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon"><i class="bi bi-buildings"></i></div>
      <div class="logo-text">
        بوابة غزة
        <small>للعقارات</small>
      </div>
    </div>
    
    <div class="sidebar-nav">
      <div class="nav-section-title">القائمة الرئيسية</div>
      <a asp-controller="Home" asp-action="Index" class="sidebar-link">
        <i class="bi bi-house"></i> الصفحة الرئيسية
      </a>
      <a asp-controller="Properties" asp-action="Dashboard" class="sidebar-link @(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")">
        <i class="bi bi-grid-1x2"></i> لوحة التحكم
      </a>
      <a asp-controller="Properties" asp-action="AddProperty" class="sidebar-link @(ViewContext.RouteData.Values["Action"].ToString() == "AddProperty" ? "active" : "")">
        <i class="bi bi-plus-square"></i> إضافة عقار
      </a>
      
      <div class="nav-section-title mt-3">الإعدادات</div>
      <a href="#" class="sidebar-link">
        <i class="bi bi-person"></i> الملف الشخصي
      </a>
    </div>
    
    <div class="sidebar-footer">
      <div class="sidebar-user mb-3">
        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(User.Identity?.Name ?? "User")&background=F5A623&color=fff" alt="User" class="rounded-circle border border-warning" width="38" height="38">
        <div class="user-info">
          <div>@User.Identity?.Name</div>
          <small class="text-white-50">مستخدم مسجل</small>
        </div>
      </div>
      <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
        <button type="submit" class="sidebar-link text-danger bg-danger bg-opacity-10 m-0 border-0 w-100 text-start">
          <i class="bi bi-box-arrow-right"></i> تسجيل الخروج
        </button>
      </form>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="dashboard-content">
    <button id="sidebarToggleBtn" class="btn d-lg-none mb-3">
      <i class="bi bi-list fs-3"></i>
    </button>
    
    @RenderBody()

  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/main.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
