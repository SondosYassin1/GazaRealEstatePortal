@{
    ViewData["Title"] = "404 - الصفحة غير موجودة";
    Layout = null; // No layout for this as per design
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بوابة غزة للعقارات - 404 الصفحة غير موجودة</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="~/css/main.css" asp-append-version="true">
</head>
<body>

<div class="error-page">
  <div class="error-page-content mx-auto">
    <div class="error-code">404</div>
    <div class="error-message">عذراً، الصفحة غير موجودة</div>
    <p class="error-desc">يبدو أن الصفحة التي تبحث عنها قد تم نقلها أو حذفها، أو أنك أدخلت الرابط بشكل خاطئ.</p>
    
    <a asp-controller="Home" asp-action="Index" class="btn-primary-custom btn-error-return d-inline-flex justify-content-center align-items-center gap-2">
      <i class="bi bi-house-door"></i> العودة للصفحة الرئيسية
    </a>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/main.js" asp-append-version="true"></script>
</body>
</html>
