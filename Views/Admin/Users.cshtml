@model List<GazaRealEstatePortal.Models.User>
@{
    ViewData["Title"] = "إدارة المستخدمين";
    Layout = "~/Views/Shared/_AdminDashboardLayout.cshtml";
}

<div class="dashboard-header d-block d-md-flex">
  <div>
    <h1>إدارة المستخدمين</h1>
    <p>عرض تفاصيل المستخدمين في المنصة.</p>
  </div>
  <div class="mt-3 mt-md-0 search-bar-wrap w-100 max-w-300">
    <input type="text" placeholder="بحث باسم المستخدم...">
    <i class="bi bi-search search-icon"></i>
  </div>
</div>

<div class="alert alert-secondary border-secondary-subtle">
    <i class="bi bi-info-circle-fill me-2"></i> هذه الشاشة للعرض فقط كجزء من الصلاحيات الإدارية المحدودة حالياً.
</div>

<!-- USERS TABLE -->
<div class="card-custom p-4 mt-3">
  
  @if (!Model.Any())
  {
      <div class="alert alert-info">لا يوجد مستخدمين.</div>
  }
  else
  {
      <div class="table-responsive">
        <table class="table-custom">
          <thead>
            <tr>
              <th>المعرف</th>
              <th>المستخدم</th>
              <th>البريد الإلكتروني</th>
              <th>رقم الهاتف</th>
              <th>الدور</th>
              <th>تاريخ التسجيل</th>
              <th>الحالة</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var user in Model)
            {
                <tr>
                  <td>#@user.Id</td>
                  <td>
                    <div class="d-flex align-items-center gap-3">
                      <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(user.FullName)&background=random" class="avatar-40" alt="User">
                      <div class="fw-bold text-primary">@user.FullName</div>
                    </div>
                  </td>
                  <td dir="ltr" class="text-end">@user.Email</td>
                  <td dir="ltr" class="text-end">@user.PhoneNumber</td>
                  <td>
                      @if (user.Role == GazaRealEstatePortal.Models.Enums.UserRole.Admin)
                      {
                          <span class="badge-custom badge-danger">مشرف</span>
                      }
                      else
                      {
                          <span class="badge-custom badge-primary-soft">مستخدم مسجل</span>
                      }
                  </td>
                  <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                  <td>
                      @if (user.IsActive)
                      {
                          <span class="badge-custom badge-success">نشط</span>
                      }
                      else
                      {
                          <span class="badge-custom badge-danger border">غير نشط</span>
                      }
                  </td>
                </tr>
            }
          </tbody>
        </table>
      </div>
  }
</div>
