@{
    ViewData["Title"] = "تم رفض الوصول";
    Layout = null; // No layout for this as per design
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بوابة غزة للعقارات - تم رفض الوصول</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="~/css/main.css" asp-append-version="true">
</head>
<body>

<div class="error-page">
  <div class="error-page-content mx-auto">
    <div class="error-code text-danger text-shadow-danger">403</div>
    <div class="error-message">عذراً، تم رفض الوصول</div>
    <p class="error-desc">ليس لديك الصلاحيات الكافية للوصول إلى هذه الصفحة. يرجى التأكد من تسجيل الدخول بحساب يمتلك الصلاحيات المطلوبة.</p>
    
    <div class="d-flex gap-3 justify-content-center">
      <a asp-controller="Home" asp-action="Index" class="btn-primary-custom btn-error-return d-flex align-items-center gap-2">
        <i class="bi bi-house-door"></i> العودة للرئيسية
      </a>
      <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary d-flex align-items-center btn-error-login">
        تسجيل الدخول
      </a>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/main.js" asp-append-version="true"></script>
</body>
</html>
